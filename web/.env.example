# Optional: CryptoPanic developer API token for dashboard news flow (server-only).
# CRYPTOPANIC_AUTH_TOKEN=

# Optional (Azure Cache for Redis): shared ticker cache for production scale.
# Omit on Mac/local dev if you cannot reach company Azure — app falls back to direct Binance.
# REDIS_URL=rediss://:<key>@<name>.redis.cache.windows.net:6380
# AZURE_REDIS_CONNECTION_STRING= (same as REDIS_URL if you prefer this name)

# Secret for POST /api/internal/ticker-ingest (timer job on Azure). Required only when using Redis ingest.
# TICKER_INGEST_SECRET=
