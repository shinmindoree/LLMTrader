# ===== Required =====

# Backend API URL
API_ORIGIN=http://localhost:8000

# Admin token for admin-only API routes (required in production)
ADMIN_TOKEN=

# ===== Authentication (Entra ID / External ID) =====

# Set to "true" to enable Entra authentication
NEXT_PUBLIC_ENTRA_AUTH_ENABLED=false
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=

# Workforce tenant (default — for org accounts):
# ENTRA_AUTHORITY=https://login.microsoftonline.com/{tenant_id}
# NEXT_PUBLIC_ENTRA_AUTHORITY=https://login.microsoftonline.com/{tenant_id}

# External ID / CIAM (for consumer accounts + Google social login):
# ENTRA_AUTHORITY=https://{subdomain}.ciamlogin.com/{tenant_id}
# NEXT_PUBLIC_ENTRA_AUTHORITY=https://{subdomain}.ciamlogin.com/{tenant_id}

# ===== Relay Server (LLM strategy generation) =====

RELAY_SERVER_URL=
RELAY_API_KEY=

# ===== Monitoring =====

# Sentry DSN for frontend error tracking (leave empty to disable)
NEXT_PUBLIC_SENTRY_DSN=

# ===== SEO =====

# Public site URL for OG tags, sitemap, robots.txt
NEXT_PUBLIC_SITE_URL=https://alphaweaver.com
