# ===== Required =====

# Backend API URL
API_ORIGIN=http://localhost:8000

# Admin token for admin-only API routes (required in production)
ADMIN_TOKEN=

# ===== Authentication (Entra ID) =====

# Set to "true" to enable Entra ID authentication
NEXT_PUBLIC_ENTRA_AUTH_ENABLED=false
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
# Optional: override authority URL
# ENTRA_AUTHORITY=https://login.microsoftonline.com/{tenant_id}

# ===== Authentication (Supabase - legacy) =====

# Set to "true" to enable Supabase authentication
# NEXT_PUBLIC_SUPABASE_AUTH_ENABLED=false
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ===== Relay Server (LLM strategy generation) =====

RELAY_SERVER_URL=
RELAY_API_KEY=

# ===== Monitoring =====

# Sentry DSN for frontend error tracking (leave empty to disable)
NEXT_PUBLIC_SENTRY_DSN=

# ===== SEO =====

# Public site URL for OG tags, sitemap, robots.txt
NEXT_PUBLIC_SITE_URL=https://alphaweaver.com
