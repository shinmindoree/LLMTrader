.env
.venv
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.cache/
.azure/
dist/
build/
.git/
.DS_Store
data/
# Strategy param artifacts are config-as-code and must ship inside the runner
# image (param_store local-first resolution). Re-include only this subtree.
!data/strategy_params
!data/strategy_params/**
test/
*.log
scripts/*.log
scripts/*.txt
scripts/*.jsonl
scripts/_*.md
web/node_modules/
web/.next/

# Alpha-lab artefacts (huge, repo-root only; not needed in any image)
alpha_lab_*.json
sweep_*.json
sweep_*.txt
engine_*.json
*_strategy.json
*.parquet
*.parquet.corrupt-*

# Local experiment / sweep outputs (repo-root)
mfp_*.json
run_*.json
la*.json

# Ad-hoc analysis / debug scripts (anything starting with _)
scripts/_*.py

# Logs / runtime state at repo root
runner.log
.runtime_strategies/
.tmp/
--symbol
